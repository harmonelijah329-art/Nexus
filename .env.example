# Environment Configuration
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://nexus:nexus_dev_password@localhost:5432/nexus
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Security
BCRYPT_ROUNDS=10
ENCRYPTION_KEY=your_encryption_key_here

# API Gateway
GATEWAY_PORT=3000
GATEWAY_RATE_LIMIT=100
GATEWAY_WINDOW_MS=900000

# WebSocket
WEBSOCKET_PORT=3001
WEBSOCKET_URL=ws://localhost:3001

# Services
AUTH_SERVICE_URL=http://localhost:3100
MESSAGING_SERVICE_URL=http://localhost:3101
PRESENCE_SERVICE_URL=http://localhost:3102

# Logging
LOG_LEVEL=info

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
